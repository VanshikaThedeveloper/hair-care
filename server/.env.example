# =============================================
# VERTEX HAIR CARE - SERVER ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values

PORT=5000
NODE_ENV=development

# ---- DATABASE ----
# Use MongoDB Atlas URI or local MongoDB
MONGO_URI=mongodb://localhost:27017/vertex
# [REPLACE] For production: mongodb+srv://<user>:<password>@cluster.mongodb.net/vertex

# ---- JWT SECRETS ----
# Generate strong random strings for production
JWT_ACCESS_SECRET=vertex_access_secret_change_in_production
JWT_REFRESH_SECRET=vertex_refresh_secret_change_in_production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ---- CLIENT URL ----
CLIENT_URL=http://localhost:5173

# ---- EMAIL (Nodemailer) ----
# [REPLACE] Your Gmail credentials (use App Password for Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Vertex Hair Care <your_email@gmail.com>

# ---- RAZORPAY (Payment Gateway) ----
# [REPLACE] Get from https://razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---- ADMIN ----
ADMIN_EMAIL=admin@vertex.com
ADMIN_PASSWORD=Admin@123456
